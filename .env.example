# Secrets and per-environment values only.
# All tuning (models, chunking, retrieval, generation) lives in src/config.py.
# Override any default here only if it must differ for this environment.

# OpenAI
OPENAI_API_KEY=sk-...

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# LangGraph checkpointer (optional; falls back to in-memory if unset)
# CHECKPOINTER_DSN=postgresql://user:pass@host:5432/dbname

# OCR. Every PDF is OCR'd. The primary engine is Mistral (cloud, default),
# with local ocrmypdf+Tesseract as the automatic fallback when Mistral errors
# or the PDF is too large. MISTRAL_API_KEY is required for the default engine.
# Set OCR_ENGINE=tesseract to make Tesseract primary (no key needed), or
# ENABLE_OCR=false to skip OCR and use Docling's native text layer.
MISTRAL_API_KEY=...
# OCR_ENGINE=mistral          # default; "tesseract" to flip primary/fallback
# MISTRAL_MAX_PDF_MB=50       # PDFs over this skip Mistral, go straight to Tesseract
# ENABLE_OCR=false
