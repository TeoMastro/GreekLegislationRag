# Secrets and per-environment values only.
# All tuning (models, chunking, retrieval, generation) lives in src/config.py.
# Override any default here only if it must differ for this environment.

# OpenAI
OPENAI_API_KEY=sk-...

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# LangGraph checkpointer (optional; falls back to in-memory if unset)
# CHECKPOINTER_DSN=postgresql://user:pass@host:5432/dbname

# OCR engine for scanned/image-only PDFs. Default is local Tesseract (free, no
# key). Set OCR_ENGINE=mistral to use Mistral's cloud OCR instead (better on
# Greek scans, no system deps, but paid per page). Requires MISTRAL_API_KEY.
# OCR_ENGINE=mistral
# MISTRAL_API_KEY=...
