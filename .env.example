# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# Metadata enrichment (cheaper model)
METADATA_LLM_MODEL=gpt-4o-mini
ENABLE_LLM_METADATA=true

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_TABLE=documents

# Paths
DOWNLOADS_DIR=downloads

# Chunking / retrieval
CHUNK_TOKENS=512
TOP_K=10
HYBRID_FULL_TEXT_WEIGHT=1.0
HYBRID_SEMANTIC_WEIGHT=1.0
RRF_K=50

# Generation
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
